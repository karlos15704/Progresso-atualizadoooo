# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# SUPABASE_SERVICE_ROLE_KEY: Chave para operações administrativas (criar professores, resetar senhas)
# Encontre em: Supabase Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# VITE_SUPABASE_URL: The URL of your Supabase project
VITE_SUPABASE_URL=

# VITE_SUPABASE_ANON_KEY: The anon key of your Supabase project
VITE_SUPABASE_ANON_KEY=

# APP_URL: Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# VAPID Keys for Push Notifications
# Generate new keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BBIRjtfRMYIYh6BcB9kfp26uOYvbEX4ecWP50-mbb0grmGNdIR8L_k1I-pMdjBBocxOaFQRnJYAMUIEdwA-7Z6M
VAPID_PRIVATE_KEY=wluC8QGJwUnpXbtKCpK5UX-Y87CPU_4u094FvJ_11VA
VAPID_MAILTO=mailto:ti@cps.local

# Email Configuration (Nodemailer)
SMTP_HOST=
SMTP_PORT=
