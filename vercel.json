{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/admin/parse-exam-file",
      "destination": "/api/parse-exam-edge.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "framework": "vite"
}
